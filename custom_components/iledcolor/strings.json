{
  "config": {
    "flow_title": "{name}",
    "step": {
      "confirm": {
        "title": "iLEDcolor LED Matrix",
        "description": "Set up {name} ({size})?"
      },
      "user": {
        "title": "iLEDcolor LED Matrix",
        "description": "Select your LED matrix.",
        "data": {
          "address": "Device"
        }
      }
    },
    "abort": {
      "no_devices_found": "No Bluetooth devices found. Make sure the device is powered on, in range, and not connected to the phone app.",
      "already_configured": "This device is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Status display",
        "description": "Pick the entities to rotate on the matrix. Panel size / font / color type / frame generation are set from the device settings.",
        "data": {
          "entities": "Entities to display"
        }
      }
    }
  },
  "entity": {
    "light": {
      "text_color": { "name": "Text color" }
    },
    "number": {
      "update_interval": { "name": "Update interval" },
      "speed": { "name": "Speed" },
      "dwell": { "name": "Dwell" },
      "mtu": { "name": "MTU (0 = auto)" },
      "panel_width": { "name": "Panel width (0 = auto)" },
      "panel_height": { "name": "Panel height (0 = auto)" },
      "weight": { "name": "Font weight (0 = regular, 1-2 = bold)" },
      "text_height": { "name": "Font height (slide)" }
    },
    "select": {
      "display_mode": {
        "name": "Display mode",
        "state": { "status": "Status display", "text": "Text input" }
      },
      "effect": { "name": "Effect" },
      "font": {
        "name": "Font",
        "state": {
          "pretendard": "Pretendard",
          "unifont": "GNU Unifont",
          "d2coding": "D2Coding",
          "galmuri14": "Galmuri 14",
          "cafe24ssurround": "Cafe24 Ssurround",
          "cafe24ssurroundair": "Cafe24 Ssurround Air",
          "mona12": "Mona 12"
        }
      },
      "color_type": {
        "name": "Color type",
        "state": { "auto": "Auto", "mono": "Mono", "full": "Full color" }
      },
      "generation": {
        "name": "Frame generation",
        "state": { "legacy": "Legacy", "app2024": "App 2024" }
      }
    },
    "switch": {
      "slide": { "name": "Slide (scroll long text)" },
      "flip_h": { "name": "Flip horizontal" },
      "flip_v": { "name": "Flip vertical" },
      "color_random": { "name": "Random color" }
    },
    "text": {
      "display_text": { "name": "Display text" }
    }
  },
  "services": {
    "send_raw": {
      "name": "Send raw frame",
      "description": "Write raw bytes to the device for protocol experimentation.",
      "fields": {
        "data": {
          "name": "Data (hex)",
          "description": "Hex byte string, e.g. 54 09 00 04 05 00 00 66."
        },
        "characteristic": {
          "name": "Characteristic",
          "description": "write1 (A951, commands) or write2 (A952, bulk)."
        }
      }
    },
    "display_text": {
      "name": "Display text",
      "description": "Rasterize text and send it to the panel as pixels (experimental, unverified on hardware).",
      "fields": {
        "text": { "name": "Text", "description": "Text to show." },
        "color": { "name": "Color", "description": "RGB color (full-color panels only)." },
        "effect": { "name": "Effect", "description": "Effect/scroll mode byte (0 = static)." },
        "speed": { "name": "Speed", "description": "Scroll/animation speed byte." },
        "slide": { "name": "Slide", "description": "Keep the font size fixed and scroll long text horizontally (auto left scroll)." }
      }
    },
    "display_image": {
      "name": "Display image",
      "description": "Load an image (path or URL), fit it to the panel, and send it as pixels (experimental).",
      "fields": {
        "source": { "name": "Source", "description": "Local file path or http(s) URL." },
        "fit": { "name": "Fit", "description": "How to fit the image to the panel." }
      }
    },
    "display_gif": {
      "name": "Display GIF",
      "description": "Load a GIF (path or URL) and send it. Raw on gif-capable panels, else decoded to pixels (experimental).",
      "fields": {
        "source": { "name": "Source", "description": "Local file path or http(s) URL." },
        "fit": { "name": "Fit", "description": "How to fit decoded frames (ignored for raw GIF)." }
      }
    }
  }
